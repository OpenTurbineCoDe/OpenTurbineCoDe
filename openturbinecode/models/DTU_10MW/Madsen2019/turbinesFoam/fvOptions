FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvOptions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


turbine
{
    type            axialFlowTurbineALSource;
    active          on;

    axialFlowTurbineALSourceCoeffs
    {
        fieldNames          (U);
        selectionMode       cellSet; // cellSet || points || cellZone
        cellSet             turbine;
        origin              (0 0 0);
        axis                (-1 0 0);
        verticalDirection   (0 0 1);
        freeStreamVelocity  (10 0 0);
        tipSpeedRatio       6.0;
        rotorRadius         86.366;

        dynamicStall
        {
            active          off;
            dynamicStallModel LeishmanBeddoes;
        }

        endEffects
        {
            active          on;
            endEffectsModel Glauert; // Glauert || Shen || liftingLine
            GlauertCoeffs
            {
                tipEffects  on;
                rootEffects on;
            }
            ShenCoeffs
            {
                c1          0.125;
                c2          21;
                tipEffects  on;
                rootEffects on;
            }
        }

        blades
        {
            blade1
            {
                writePerf   true;
                writeElementPerf true;
                nElements   80;
                elementProfiles
                (
                    cylinder
                    cylinder
                    FFA_W3_600
                    FFA_W3_600
                    FFA_W3_600
                    FFA_W3_480
                    FFA_W3_480
                    FFA_W3_360
                    FFA_W3_360
                    FFA_W3_301
                    FFA_W3_301
                    FFA_W3_301
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                    FFA_W3_241
                );
                elementData
                (
                    #include "elementData"
                );
            }
            blade2
            {
                $blade1;
                writePerf   false;
                writeElementPerf false;
                azimuthalOffset 120.0;
            }
            blade3
            {
                $blade2;
                azimuthalOffset 240.0;
            }
        }

        tower
        {
            includeInTotalDrag  false;
            nElements   22;
            elementProfiles (cylinder);
            elementData
            ( 
                (0.0   0.00   8.3)     // TwrElev, TwrDiam
                (0.0  11.50   8.022)
                (0.0  23.00   7.743)
                (0.0  34.50   7.465)
                (0.0  46.00   7.186)
                (0.0  57.50   6.908)
                (0.0  69.00   6.629)
                (0.0  80.50   6.351)
                (0.0  92.00   6.072)
                (0.0 103.50   5.794)
                (0.0 115.60   5.500)
            );
        }

        hub
        {
            nElements   1;
            elementProfiles (cylinder);
            elementData
            ( 
                (0   0.0    2.8)  // Axial distance, hub height, hub diameter
                (0  -0.0    2.8)
            );
        }

        profileData
        {
            FFA_W3_241
            {
                data (#include "../../resources/foilData/FFA_W3_241");
            }
            FFA_W3_301
            {
                data (#include "../../resources/foilData/FFA_W3_301");
            }
            FFA_W3_360
            {
                data (#include "../../resources/foilData/FFA_W3_360");
            }
            FFA_W3_480
            {
                data (#include "../../resources/foilData/FFA_W3_480");
            }
            FFA_W3_600
            {
                data (#include "../../resources/foilData/FFA_W3_600");
            }
            cylinder
            {
                data (#include "../../resources/foilData/Cylinder");
            }
        }
    }
}

